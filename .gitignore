# Models (large binary files — download separately)
models/
*.onnx
*.onnx.json

# macOS
.DS_Store
.AppleDouble

# Windows
Thumbs.db
desktop.ini

# Logs
*.log
waylay.log
waylay_error.log
ollama.log

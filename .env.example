# Waylay — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── API Keys ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=               # Free at console.groq.com (Groq fallback LLM)
OPENWEATHER_API_KEY=        # Free at openweathermap.org

# ── Google OAuth (Gmail, Calendar) ───────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=./credentials.json

# ── Microsoft (Teams, Outlook) ────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=        # From Azure App Registration (optional)
MICROSOFT_TENANT_ID=common

# ── Ollama (local LLM — PRIMARY) ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b     # Main reasoning model
INTENT_FILTER_MODEL=llama3.2:3b  # Fast intent classifier (COMMAND vs NOISE)

# ── Voice — edge-tts (PRIMARY, free, no API key) ─────────────────────────────
# Voice options:
#   en-US-AriaNeural   — warm, natural, casual (DEFAULT)
#   en-US-JennyNeural  — casual, friendly
#   en-GB-SoniaNeural  — British female, formal
#   en-US-AnaNeural    — young, energetic
VOICE_NAME=en-US-AriaNeural
VOICE_RATE=+5%
VOICE_PITCH=-5Hz

# ── Voice — Piper TTS (OFFLINE FALLBACK) ─────────────────────────────────────
# macOS/Linux:  ./models/en_US-lessac-medium.onnx
# Windows:      .\models\en_US-lessac-medium.onnx
PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx

# ── User Config ───────────────────────────────────────────────────────────────
USER_NAME=Gavin
USER_LOCATION=Bengaluru

# ── Phone (ADB) ───────────────────────────────────────────────────────────────
PHONE_SERIAL=               # From 'adb devices' output
